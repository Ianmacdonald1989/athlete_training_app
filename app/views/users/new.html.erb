<% content_for :title, "Create account" %>

<h1>Create account</h1>

<%= form_with model: @user, url: users_path, local: true do |f| %>
  <% if @user.errors.any? %>
    <div class="alert">
      <h2><%= pluralize(@user.errors.count, "error") %> prevented this account from being created:</h2>
      <ul>
        <% @user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :email %>
    <%= f.email_field :email, autocomplete: "username" %>
  </div>

  <div>
    <%= f.label :password %>
    <%= f.password_field :password, autocomplete: "new-password" %>
  </div>

  <div>
    <%= f.label :password_confirmation %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
  </div>

  <div>
    <%= f.submit "Create account" %>
  </div>
<% end %>

<p class="muted">
  Already have an account?
  <%= link_to "Sign in", new_session_path %>
</p>
