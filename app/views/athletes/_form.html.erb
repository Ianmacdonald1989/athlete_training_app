<%= form_with(model: athlete) do |form| %>
  <% if athlete.errors.any? %>
    <div class="alert">
      <h2><%= pluralize(athlete.errors.count, "error") %> prohibited this athlete from being saved:</h2>

      <ul>
        <% athlete.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
