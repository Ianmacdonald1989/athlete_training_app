<h1><%= sport_icon(@athlete.sport_definition) %> <%= @athlete.name %> - Stats</h1>

<div class="grid-list">
  <div class="card">
    <h2>Total Distance</h2>
    <p><strong><%= @total_distance.round(2) %> km</strong></p>
  </div>
  <div class="card">
    <h2>Average Speed</h2>
    <p><strong><%= @average_speed.round(2) %> km/h</strong></p>
  </div>
</div>

<h2>Training Sessions</h2>

<% if @training_sessions.any? %>
  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>Start Time</th>
        <th>Finish Time</th>
        <th>Distance (km)</th>
        <th>Average Speed (km/h)</th>
      </tr>
    </thead>
    <tbody>
      <% @training_sessions.each do |session| %>
        <tr>
          <td><%= session.date %></td>
          <td><%= session.start_time&.strftime("%Y-%m-%d %H:%M") %></td>
          <td><%= session.finish_time&.strftime("%Y-%m-%d %H:%M") %></td>
          <td><%= session.total_distance %></td>
          <td><%= session.average_speed %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No training sessions recorded yet.</p>
<% end %>

<div class="actions">
  <%= link_to "Back to profile", athlete_path(@athlete), class: "btn-secondary btn" %>
</div>
