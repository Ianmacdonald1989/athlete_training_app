<% if notice.present? %>
  <p class="notice"><%= notice %></p>
<% end %>

<% content_for :title, "Athletes" %>

<h1>Athletes</h1>

<div id="athletes" class="grid-list">
  <% @athletes.each do |athlete| %>
    <%= render athlete %>
  <% end %>
</div>

<div class="actions">
  <%= link_to "New athlete", new_athlete_path, class: "btn" %>
</div>
