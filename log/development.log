27:            const theme = savedTheme || (prefersDark ? "dark" : "light");
28:            document.documentElement.setAttribute("data-theme", theme);
29:          })();
30:        </script>
31:      </head>
32:    
33:      <body>
34:        <main class="page-shell">
35:          <header class="app-header">
36:            <%= link_to "Athlete Training App", athletes_path, class: " %>
37:            <button id="theme-toggle" class="theme-switch" type="button" role="switch" aria-label="Toggle dark mode" aria-checked="false">
38:              <span class="theme-switch-track">
39:                <span class="theme-switch-thumb"></span>
40:              </span>
41:              <span class="theme-switch-label">Dark mode</span>
42:            </button>
43:          </header>
44:          <%= yield %>
45:        </main>
46:        <script>
47:          (function() {
48:            const themeToggle = document.getElementById("theme-toggle");
49:            if (!themeToggle) return;
50:    
51:            function updateToggle(theme) {
52:              const isDark = theme === "dark";
53:              themeToggle.setAttribute("aria-checked", isDark ? "true" : "false");
54:              themeToggle.setAttribute("title", isDark ? "Switch to light mode" : "Switch to dark mode");
55:            }
56:    
57:            let currentTheme = document.documentElement.getAttribute("data-theme") || "light";
58:            updateToggle(currentTheme);
59:    
60:            themeToggle.addEventListener("click", function() {
61:              currentTheme = currentTheme === "dark" ? "light" : "dark";
62:              document.documentElement.setAttribute("data-theme", currentTheme);
63:              localStorage.setItem("theme", currentTheme);
64:              updateToggle(currentTheme);
65:            });
66:          })();
67:        </script>
68:      </body>
69:    </html>
  
